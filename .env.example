# Santander Cycles Pipeline — environment variables
# Copy to .env and fill in your values.
# All vars must use `export` so subprocesses (Bruin, gcloud, etc.) inherit them after `source .env`.

# ── User-configurable ─────────────────────────────────────────────────────────
export GCP_PROJECT=your-gcp-project-id
export LOCATION=your-gcp-region          # e.g. asia-southeast1, europe-west2

# Years to ingest (JSON array passed to Bruin)
export YEARS="2024"                      # e.g. "2021" or "[2021,2022,2023]"

# Terraform credentials (use absolute path)
export TF_VAR_credentials=/absolute/path/to/keys/terraform-sa-key.json

# ── Pre-set (match Terraform outputs — only change if you renamed resources) ──
export GCS_BKT=${GCP_PROJECT}-bkt
export BQ_DS_RAW=san_cycles_raw
export BQ_DS_STG=san_cycles_stg
export BQ_DS_MRT=san_cycles_mrt
export BQ_TBL_RAW=journeys

# Relative to repo root — required for Bruin (absolute paths break Bruin's path joining)
export GOOGLE_APPLICATION_CREDENTIALS=keys/gcp-sa-key.json