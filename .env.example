# User configuration, please update

# export: required so subprocesses (bruin, gcloud, etc.) see these vars after `source .env`


# - GCP_PROJECT -  GCP project ID
# - LOCATION - project location
# - YEARS - for which years to run the pipeline.
#   "[2020,2021,2022,2023]"" is the correct syntax.)
#   Max range 2012-2025. 2026 can be included, but not very meaningful). Default option is "all", but that crashes the dataframe.
# - TF_VAR_credentials - need to save down Terraform Service Account key, with permissions listed.
# - Keys are stored at project root/keys/ directory.

export GCP_PROJECT=san-cycles-data-pipe
export LOCATION=asia-southeast1
export YEARS="all"
export TF_VAR_credentials=../keys/terraform-sa-key.json


######################################################

# Pre-set variables below, don't change
export GCS_BKT=san-cycles-data-pipe-bkt
export BQ_DS_RAW=san_cycles_raw
export BQ_DS_STG=san_cycles_stg
export BQ_DS_MRT=san_cycles_mrt
export BQ_TBL_RAW=journeys

# Relative to repo root (required for Bruin; absolute paths get joined with project dir and break)

export GOOGLE_APPLICATION_CREDENTIALS=keys/gcp-sa-key.json